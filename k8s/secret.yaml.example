# Copy to secret.yaml, fill in real values, then:
#   kubectl apply -f k8s/secret.yaml
# Never commit secret.yaml — it is in .gitignore
apiVersion: v1
kind: Secret
metadata:
  name: mathquiz-secrets
  namespace: mathquiz
type: Opaque
stringData:
  JWT_SECRET:         "change-this-to-a-32-char-random-string"
  ANTHROPIC_API_KEY:  "sk-ant-..."
  POSTGRES_PASSWORD:  "postgres"
